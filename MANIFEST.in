include LICENSE.txt
include pyproject.toml
include CMakeLists.txt

# sources of extensions (incl. cython)
recursive-include src/deeptime *.pyx *.h *.hpp *.c *.cpp *.npz CMakeLists.txt
# do not install test directory
recursive-exclude tests *

prune tests
prune docs
prune *.egg-info
prune .github
prune examples
prune cmake-build-*
